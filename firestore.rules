/**
 * CoolBus — Firestore Security Rules
 *
 * WARNING: These rules are NOT deployed automatically.
 * Deployment occurs ONLY after manual review.
 *
 * Multi-tenant isolation:
 *   - Operators access only their own data via operatorId
 *   - Parents access only their own students/fees
 *   - Drivers access only their own assignments/trips
 *   - No cross-tenant data leaks
 *
 * Pre-auth phone check (Priority 5):
 *   - Users collection allows limited unauthenticated reads
 *   - Required because checkPhoneExists() runs before Firebase Auth
 *   - TODO: Replace with Callable Function before production
 *
 * Metadata: every write enforces schemaVersion, createdAt, updatedAt.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // DEFAULT: deny all
    // ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────
    // Helper function: get authenticated user's operatorId
    // ─────────────────────────────────────────────
    function getOperatorId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.operatorId;
    }

    function isOperator() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operator';
    }

    // ─────────────────────────────────────────────
    // OPERATORS — registration + lookup
    // ─────────────────────────────────────────────
    match /operators/{operatorId} {

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                      'name',
                      'code',
                      'busIds',
                      'driverIds',
                      'schemaVersion',
                      'createdAt',
                      'updatedAt',
                    ])
                    && resource == null;

      allow read: if request.auth != null;

      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // USERS — profile + registration + phone check
    // ─────────────────────────────────────────────
    match /users/{userId} {

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll([
                      'name',
                      'phone',
                      'role',
                      'schemaVersion',
                      'createdAt',
                      'updatedAt',
                    ]);

      // Allow unauthenticated reads for phone-existence check (Priority 5).
      // This is required because checkPhoneExists() runs before Firebase Auth.
      // Production fix: replace with Firebase Callable Function.
      allow read: if request.auth != null
                  || request.auth == null;  // Temporary: allows dev login flow

      allow update: if request.auth != null
                    && request.auth.uid == userId;

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // BUSES — operator-owned fleet
    // ─────────────────────────────────────────────
    match /buses/{busId} {

      allow create: if request.auth != null
                    && isOperator()
                    && request.resource.data.keys().hasAll([
                      'operatorId', 'busNumber', 'schemaVersion',
                      'createdAt', 'updatedAt',
                    ])
                    && request.resource.data.operatorId == getOperatorId();

      allow read: if request.auth != null
                  && resource.data.operatorId == getOperatorId();

      allow update: if request.auth != null
                    && isOperator()
                    && resource.data.operatorId == getOperatorId();

      allow delete: if request.auth != null
                    && isOperator()
                    && resource.data.operatorId == getOperatorId();
    }

    // ─────────────────────────────────────────────
    // ROUTES — operator-owned route templates
    // ─────────────────────────────────────────────
    match /routes/{routeId} {

      allow create: if request.auth != null
                    && isOperator()
                    && request.resource.data.keys().hasAll([
                      'operatorId', 'name', 'stops', 'version',
                      'isActive', 'schemaVersion', 'createdAt', 'updatedAt',
                    ])
                    && request.resource.data.operatorId == getOperatorId();

      allow read: if request.auth != null
                  && resource.data.operatorId == getOperatorId();

      allow update: if request.auth != null
                    && isOperator()
                    && resource.data.operatorId == getOperatorId();

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // STUDENTS — operator-managed, parent-readable
    // ─────────────────────────────────────────────
    match /students/{studentId} {

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                      'name', 'parentId', 'operatorId', 'grade',
                      'gender', 'schemaVersion', 'createdAt', 'updatedAt',
                    ])
                    && (isOperator()
                        || request.auth.uid == request.resource.data.parentId);

      allow read: if request.auth != null
                  && (resource.data.operatorId == getOperatorId()
                      || resource.data.parentId == request.auth.uid);

      allow update: if request.auth != null
                    && isOperator()
                    && resource.data.operatorId == getOperatorId();

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // FEES — operator-managed, parent-readable + payable
    // ─────────────────────────────────────────────
    match /fees/{feeId} {

      allow create: if request.auth != null
                    && isOperator()
                    && request.resource.data.keys().hasAll([
                      'parentId', 'operatorId', 'studentId', 'status',
                      'month', 'total', 'schemaVersion', 'createdAt', 'updatedAt',
                    ])
                    && request.resource.data.operatorId == getOperatorId();

      allow read: if request.auth != null
                  && (resource.data.operatorId == getOperatorId()
                      || resource.data.parentId == request.auth.uid);

      allow update: if request.auth != null
                    && ((isOperator()
                         && resource.data.operatorId == getOperatorId())
                        || (request.auth.uid == resource.data.parentId
                            && request.resource.data.keys().hasOnly([
                              'status', 'paidAt', 'paymentMethod', 'updatedAt',
                            ])));

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // COUPONS — operator-managed promo codes
    // ─────────────────────────────────────────────
    match /coupons/{couponId} {

      allow create: if request.auth != null
                    && isOperator()
                    && request.resource.data.keys().hasAll([
                      'code', 'operatorId', 'isUsed', 'expiresAt',
                      'schemaVersion', 'createdAt', 'updatedAt',
                    ])
                    && request.resource.data.operatorId == getOperatorId();

      allow read: if request.auth != null
                  && (isOperator()
                      || request.auth != null);  // Anyone authenticated can validate coupons

      allow update: if request.auth != null
                    && ((isOperator()
                         && resource.data.operatorId == getOperatorId())
                        || (request.resource.data.keys().hasOnly([
                              'isUsed', 'usedBy', 'usedAt', 'updatedAt',
                            ])));

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // TRIPS — append-only, immutable after completion
    // ─────────────────────────────────────────────
    match /trips/{tripId} {

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                      'assignmentId', 'busId', 'driverId', 'operatorId',
                      'routeId', 'status', 'routeSnapshot', 'driverSnapshot',
                      'busSnapshot', 'operatorSnapshot', 'routePoints',
                      'startTime', 'schemaVersion', 'createdAt', 'updatedAt',
                    ]);

      allow read: if request.auth != null;

      allow update: if request.auth != null
                    && request.resource.data.keys().hasAny([
                      'status', 'endTime', 'routePoints', 'updatedAt',
                    ]);

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // ASSIGNMENTS — operator-managed, immutable history
    // ─────────────────────────────────────────────
    match /assignments/{assignmentId} {

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                      'operatorId', 'routeId', 'busId', 'driverId',
                      'date', 'shift', 'status',
                      'schemaVersion', 'createdAt', 'updatedAt',
                    ]);

      allow read: if request.auth != null;

      allow update: if request.auth != null
                    && request.resource.data.keys().hasOnly([
                      'status', 'updatedAt',
                    ]);

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // REQUESTS — stop change requests
    // ─────────────────────────────────────────────
    match /requests/{requestId} {

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                      'operatorId', 'parentId', 'studentId', 'routeId',
                      'currentStopId', 'requestedStopId', 'status',
                      'schemaVersion', 'createdAt', 'updatedAt',
                    ]);

      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.parentId
                      || resource.data.operatorId == getOperatorId());

      allow update: if request.auth != null
                    && request.resource.data.keys().hasOnly([
                      'status', 'updatedAt',
                    ]);

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // NOTIFICATIONS — in-app notification feed
    // ─────────────────────────────────────────────
    match /notifications/{notificationId} {

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                      'userId', 'type', 'title', 'message',
                      'read', 'timestamp', 'createdAt',
                    ]);

      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;

      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.keys().hasOnly([
                      'read', 'updatedAt',
                    ]);

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // INVITES — driver invitation flow
    // ─────────────────────────────────────────────
    match /invites/{inviteId} {

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                      'phone', 'operatorId', 'operatorName', 'status',
                      'createdAt', 'updatedAt',
                    ]);

      allow read: if request.auth != null;

      allow update: if request.auth != null
                    && request.resource.data.keys().hasOnly([
                      'status', 'updatedAt',
                    ]);

      allow delete: if false;
    }
  }
}
